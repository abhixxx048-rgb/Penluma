---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../consts';
import { topics, topicsByCategory, allPosts, featuredPosts } from '../lib/content';

const posts = await allPosts();
const recent = posts.slice(0, 12);
const featuredTopics = topics.filter((t) => t.featured);
const grouped = topicsByCategory();
const totalPosts = posts.length;
const totalTopics = topics.length;

const homeUrl = new URL('/', Astro.site).toString();
const pageDescription =
  `Penluma is a growing library of deep, worked-through writing on staff-level system design, multi-agent AI, money, and thinking clearly - intuition to mechanics to failure modes.`;
const keywords = [
  'deep-dive research',
  'system design',
  'multi-agent LLM systems',
  'AI engineering',
  'economics',
  'clear thinking',
  'staff engineer',
  'Penluma',
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: SITE.name,
    description: pageDescription,
    url: homeUrl,
    isPartOf: { '@type': 'WebSite', name: SITE.name, url: homeUrl },
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: recent.map((post, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: new URL(`/blog/${post.id}/`, Astro.site).toString(),
        name: post.data.title,
      })),
    },
  },
];
---

<BaseLayout
  description={pageDescription}
  keywords={keywords}
  jsonLd={jsonLd}
>
  <!-- Hero / branding -->
  <section class="relative overflow-hidden border-b border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-5xl px-4 pt-16 pb-14 sm:px-6 sm:pt-24">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">
        {SITE.name} · pen + lumen
      </p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
        Understand hard things properly - not just enough to nod along.
      </h1>
      <p class="mt-5 max-w-2xl text-xl text-slate-600 dark:text-slate-300">{SITE.tagline}</p>
      <p class="mt-3 max-w-2xl text-slate-500 dark:text-slate-400">
        No cheat sheets, no hot takes - each deep-dive goes from plain-language intuition, to precise
        mechanics, to the failure modes that show up in the real world. The version I wish I'd had when
        I was learning it.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog" class="rounded-xl bg-brand-700 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-brand-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
          Start reading →
        </a>
        <a href="/topics" class="rounded-xl border border-slate-300 px-5 py-2.5 font-medium transition-colors hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-900">
          Explore topics
        </a>
      </div>
    </div>
  </section>

  <!-- What Penluma is -->
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">What is Penluma</p>
    <h2 class="mt-3 max-w-2xl text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
      A library of deep-dives that actually go deep.
    </h2>
    <p class="mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      Most sites hand you the summary. Penluma hands you the whole thing - system design, AI, money,
      and clear thinking, each one built from the ground up and followed all the way to where it breaks.
    </p>
    <div class="mt-6 flex flex-wrap gap-2.5">
      {['Plain-language first', 'Precise mechanics', 'Real-world failure modes'].map((chip) => (
        <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
          {chip}
        </span>
      ))}
    </div>
  </section>

  <!-- The problem -->
  <section class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 sm:p-12 dark:border-slate-800 dark:bg-slate-900/50">
      <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">The problem</p>
      <h2 class="mt-3 max-w-3xl text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
        You read the article, nodded along - and still couldn't build it.
      </h2>
      <p class="mt-4 max-w-2xl text-slate-600 dark:text-slate-300">
        Cheat sheets are too shallow. Textbooks are too dense. Hot takes age in a week. Most content
        leaves you <em>knowing about</em> a topic without actually <em>understanding</em> it - so it
        collapses the moment you hit a real problem.
      </p>
    </div>
  </section>

  <!-- The method -->
  <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">The method</p>
    <h2 class="mt-3 max-w-2xl text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
      Every topic, taken three levels deep.
    </h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      {[
        { n: '1', t: 'Intuition', d: 'The plain-language mental model - the way a smart friend would explain it before any jargon shows up.' },
        { n: '2', t: 'Mechanics', d: 'Precisely how it actually works, step by step. No hand-waving, no "it just works".' },
        { n: '3', t: 'Failure modes', d: 'Where it breaks in production, why, and what to do about it - the part most explanations skip.' },
      ].map((step) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-100 font-bold text-brand-700 dark:bg-brand-900/40 dark:text-brand-300">{step.n}</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">{step.t}</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{step.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Why we're different -->
  <section class="mx-auto max-w-5xl px-4 pb-4 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Why Penluma</p>
    <h2 class="mt-3 max-w-2xl text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
      Not another blog.
    </h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      {[
        { t: 'Depth over volume', d: 'One hard topic, fully worked through - not ten skimmed for the algorithm.' },
        { t: 'Evergreen, not news', d: 'The residue that stays true in five years, not a take that expires next week.' },
        { t: 'One voice, real understanding', d: "Written by someone who learned it the hard way - me - not stitched together for SEO." },
        { t: 'Open by default', d: 'The whole library, free. No paywall, no signup wall to read.' },
      ].map((item) => (
        <div class="flex gap-4 rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          <span class="mt-1 text-brand-600 dark:text-brand-400" aria-hidden="true">✓</span>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white">{item.t}</h3>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{item.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Proof / value band -->
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="grid grid-cols-3 gap-4 rounded-3xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-8 text-center dark:border-slate-800 dark:from-slate-900 dark:to-slate-900">
      <div>
        <p class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">{totalPosts}</p>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">deep-dives</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">{totalTopics}</p>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">topics</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-slate-900 sm:text-4xl dark:text-white">Free</p>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">no paywall, ever</p>
      </div>
    </div>
  </section>

  <!-- Featured essays (standalone, hand-written) -->
  {featuredPosts.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 pt-12 sm:px-6">
      <div class="grid gap-5 sm:grid-cols-2">
        {featuredPosts.slice(0, 2).map((p) => (
          <a href={`/blog/${p.id}`} class="group rounded-2xl border border-brand-200 bg-brand-50/50 p-6 transition-all hover:-translate-y-0.5 hover:shadow-lg dark:border-brand-900 dark:bg-brand-950/20">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">{p.icon} Featured · {p.topicTitle}</p>
            <h3 class="mt-2 text-lg font-semibold text-slate-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300">{p.title}</h3>
            <p class="mt-1.5 line-clamp-2 text-sm text-slate-600 dark:text-slate-400">{p.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Start here -->
  {featuredTopics.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Start here</h2>
      <div class="mt-4 grid gap-5 sm:grid-cols-2">
        {featuredTopics.map((t) => (
          <a href={`/topics/${t.slug}`} class="group rounded-2xl border border-slate-200 bg-gradient-to-br from-brand-50 to-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-lg dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
            <div class="text-3xl">{t.icon}</div>
            <h3 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300">{t.title}</h3>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{t.description}</p>
            <p class="mt-3 text-xs font-medium text-brand-600 dark:text-brand-400">{t.postCount} posts →</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Latest -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Latest</h2>
      <a href="/blog" class="text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">View all {totalPosts} →</a>
    </div>
    <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <!-- Explore by category -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Explore by category</h2>
    <div class="mt-4 space-y-8">
      {grouped.map((g) => (
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">{g.category}</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {g.topics.map((t) => (
              <a href={`/topics/${t.slug}`} class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-sm transition-colors hover:border-brand-300 hover:bg-brand-50 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700 dark:hover:bg-slate-800">
                <span>{t.icon}</span>{t.title}
                <span class="text-xs text-slate-400">{t.postCount}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Penluma story band - the face of the platform -->
  <section class="mx-auto mt-8 max-w-5xl px-4 sm:px-6">
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-8 sm:p-12 dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
      <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">The story behind Penluma</p>
      <h2 class="mt-3 max-w-2xl text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
        I write to understand things properly - then I publish what survived.
      </h2>
      <p class="mt-4 max-w-2xl text-slate-600 dark:text-slate-400">
        I'm {SITE.author}. Penluma is <em>pen</em> + <em>lumen</em>, the light of the pen - my habit
        of taking one hard topic at a time and writing through it until the fog clears. No cheat sheets,
        no hot takes: just the version I wish I'd had when I was learning it, taken from plain-language
        intuition all the way down to how it breaks in the real world.
      </p>
      <p class="mt-3 max-w-2xl text-slate-600 dark:text-slate-400">
        Everything here is the evergreen residue of that work - {totalPosts} deep-dives and counting,
        published so the next person learning the same thing gets there faster.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href="/about" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">More about me & Penluma →</a>
        <a href="/topics" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800">Browse the topics</a>
      </div>
    </div>
  </section>
</BaseLayout>
