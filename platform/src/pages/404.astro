---
import BaseLayout from '../layouts/BaseLayout.astro';
import { topics } from '../lib/content';
const popular = topics.filter((t) => t.featured).slice(0, 4);
---

<BaseLayout title="Page not found" description="That page went dark." noindex={true}>
  <section class="mx-auto flex max-w-2xl flex-col items-start px-4 py-24 sm:px-6">
    <p class="font-serif text-6xl font-bold text-brand-500">404</p>
    <h1 class="mt-4 font-serif text-3xl font-bold tracking-tight text-slate-900 dark:text-white">
      This page went dark.
    </h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      The page you're looking for doesn't exist or has moved. Let's get you back into the light.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class="rounded-xl bg-brand-400 px-5 py-2.5 font-semibold text-slate-950 transition-colors hover:bg-brand-300">
        Back home
      </a>
      <a href="/topics" class="rounded-xl border border-slate-300 px-5 py-2.5 font-medium transition-colors hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-900">
        Browse topics
      </a>
      <a href="/search" class="rounded-xl border border-slate-300 px-5 py-2.5 font-medium transition-colors hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-900">
        Search
      </a>
    </div>

    {popular.length > 0 && (
      <div class="mt-12 w-full">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Popular topics</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {popular.map((t) => (
            <a href={`/topics/${t.slug}`} class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-sm transition-colors hover:border-brand-300 hover:bg-brand-50 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700">
              <span>{t.icon}</span>{t.title}
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
