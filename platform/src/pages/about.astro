---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
import { topics, allPosts } from '../lib/content';
const posts = await allPosts();

const aboutUrl = new URL('/about', Astro.site).toString();
const description = `About Penluma: ${posts.length} in-depth, worked-through notes on system design, distributed systems, economics, money, and clear thinking - from intuition to mechanics to failure modes.`;

const keywords = [
  'Penluma',
  'about',
  'deep-dive notes',
  'system design',
  'distributed systems',
  'economics',
  'clear thinking',
  'money',
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: `About ${SITE.name}`,
    description,
    url: aboutUrl,
    mainEntity: {
      '@type': 'Person',
      name: SITE.author,
      url: new URL('/', Astro.site).toString(),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: 'About', item: aboutUrl },
    ],
  },
];
---

<BaseLayout title="About" description={description} keywords={keywords} jsonLd={jsonLd}>
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">About Penluma</h1>
    <div class="prose-research mt-8">
      <p>
        <strong>Penluma</strong> - <em>pen</em> + <em>lumen</em>, the light of the pen - is a growing
        library of <strong>{posts.length} deep-dive notes</strong> across
        <strong>{topics.length} topics</strong> - from staff-level system design and distributed
        systems to economics, clear thinking, and money. Each topic is written to take you from
        plain-language intuition, to precise mechanics, to the failure modes that show up in the
        real world.
      </p>
      <p>
        Unlike most online write-ups, these aren't cheat sheets. They include back-of-the-envelope
        math, worked examples, comparison tables, war stories, and test-yourself questions. They're
        meant to be read slowly and worked through.
      </p>
      <h2>Why this exists</h2>
      <p>
        I research these topics in depth for my own learning and work, and publish the evergreen
        parts here so they can help others learning the same things. New topics get added over time.
      </p>
      <h2>Stay in the loop</h2>
      <p>Subscribe below to get an email when a substantial new topic or post lands.</p>
    </div>
  </section>
</BaseLayout>
