---
interface Props {
  postId: string;
}
const { postId } = Astro.props;
---

<span class="inline-flex items-center gap-3" data-post-id={postId}>
  <span class="inline-flex items-center gap-1" title="Views">
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path><circle cx="12" cy="12" r="3"></circle>
    </svg>
    <span data-views>-</span>
  </span>
  <button
    data-like
    class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 transition-colors hover:text-rose-500 data-[liked=true]:text-rose-500"
    aria-label="Like this post"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.5 1-1a5.5 5.5 0 0 0 0-7.9z"></path>
    </svg>
    <span data-likes>-</span>
  </button>
</span>

<script>
  const root = document.querySelector('[data-post-id]') as HTMLElement | null;
  if (root) {
    const id = root.dataset.postId!;
    const viewsEl = root.querySelector('[data-views]')!;
    const likesEl = root.querySelector('[data-likes]')!;
    const likeBtn = root.querySelector('[data-like]') as HTMLButtonElement;
    const likedKey = `liked:${id}`;
    const liked = () => localStorage.getItem(likedKey) === '1';
    likeBtn.dataset.liked = String(liked());

    // Count a view at most once per browser per day.
    const viewKey = `viewed:${id}`;
    const today = new Date().toISOString().slice(0, 10);
    const alreadyViewed = localStorage.getItem(viewKey) === today;

    fetch(`/api/post/${id}`, { method: alreadyViewed ? undefined : 'GET' })
      .then((r) => r.json())
      .then((d) => {
        viewsEl.textContent = d.views ?? 0;
        likesEl.textContent = d.likes ?? 0;
        localStorage.setItem(viewKey, today);
      })
      .catch(() => {});

    likeBtn.addEventListener('click', async () => {
      const willLike = !liked();
      localStorage.setItem(likedKey, willLike ? '1' : '0');
      likeBtn.dataset.liked = String(willLike);
      try {
        const r = await fetch(`/api/post/${id}`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ action: willLike ? 'like' : 'unlike' }),
        });
        const d = await r.json();
        likesEl.textContent = d.likes ?? 0;
      } catch {
        /* ignore */
      }
    });
  }
</script>
