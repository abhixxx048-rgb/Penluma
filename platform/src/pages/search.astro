---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search all research posts." noindex={true}>
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">Search</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">Full-text search across every post.</p>
    <div id="search" class="mt-8"></div>
  </section>
</BaseLayout>

<!-- Pagefind: index is generated at build time (`pagefind --site dist`) -->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.PagefindUI) {
      new window.PagefindUI({ element: '#search', showSubResults: true, showImages: false });
    } else {
      document.getElementById('search').innerHTML =
        '<p class="text-slate-500">Search index loads after the first production build (<code>npm run build</code>).</p>';
    }
  });
</script>
