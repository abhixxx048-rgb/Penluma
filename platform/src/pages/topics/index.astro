---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicsByCategory } from '../../lib/content';
const grouped = topicsByCategory();

const allTopics = grouped.flatMap((g) => g.topics);
const topicsUrl = new URL('/topics', Astro.site).toString();

const description =
  'Browse every research topic, grouped by category - from strategy and persuasion to platform design. Each topic is a worked-through body of notes you can read like a short course.';
const keywords = [
  'research topics',
  'topics index',
  'research categories',
  ...grouped.map((g) => g.category),
  ...allTopics.slice(0, 8).map((t) => t.title),
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Topics',
    description,
    url: topicsUrl,
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: allTopics.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.title,
        description: t.description,
        url: new URL(`/topics/${t.slug}`, Astro.site).toString(),
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: 'Topics', item: topicsUrl },
    ],
  },
];
---

<BaseLayout title="Topics" description={description} keywords={keywords} jsonLd={jsonLd}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">Topics</h1>
    <p class="mt-3 max-w-2xl text-slate-600 dark:text-slate-400">
      Every topic is a worked-through body of notes - read top-to-bottom like a short course, or dip into a single post.
    </p>

    <div class="mt-10 space-y-12">
      {grouped.map((g) => (
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">{g.category}</h2>
          <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {g.topics.map((t) => (
              <a href={`/topics/${t.slug}`} class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-5 transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700">
                <div class="text-2xl">{t.icon}</div>
                <h3 class="mt-3 font-semibold text-slate-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300">{t.title}</h3>
                <p class="mt-1.5 flex-1 text-sm text-slate-600 dark:text-slate-400">{t.description}</p>
                <p class="mt-3 text-xs font-medium text-brand-600 dark:text-brand-400">{t.postCount} posts →</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
