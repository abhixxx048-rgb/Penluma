---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../consts';
import { topics, topicsByCategory, allPosts } from '../lib/content';

const posts = await allPosts();
const recent = posts.slice(0, 6);
const featured = topics.filter((t) => t.featured);
const grouped = topicsByCategory();
const totalPosts = posts.length;
---

<BaseLayout>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-12 sm:px-6 sm:pt-24">
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
      {totalPosts} deep-dives · {topics.length} topics
    </p>
    <h1 class="mt-3 max-w-3xl text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
      {SITE.tagline}
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-slate-600 dark:text-slate-400">{SITE.description}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/topics" class="rounded-xl bg-brand-600 px-5 py-2.5 font-medium text-white transition-colors hover:bg-brand-700">
        Browse topics
      </a>
      <a href="/blog" class="rounded-xl border border-slate-300 px-5 py-2.5 font-medium transition-colors hover:bg-slate-50 dark:border-slate-700 dark:hover:bg-slate-900">
        All posts
      </a>
    </div>
  </section>

  <!-- Featured topics -->
  {featured.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Start here</h2>
      <div class="mt-4 grid gap-5 sm:grid-cols-2">
        {featured.map((t) => (
          <a href={`/topics/${t.slug}`} class="group rounded-2xl border border-slate-200 bg-gradient-to-br from-brand-50 to-white p-6 transition-all hover:-translate-y-0.5 hover:shadow-lg dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
            <div class="text-3xl">{t.icon}</div>
            <h3 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300">{t.title}</h3>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{t.description}</p>
            <p class="mt-3 text-xs font-medium text-brand-600 dark:text-brand-400">{t.postCount} posts →</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Recent posts -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Latest</h2>
      <a href="/blog" class="text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">View all →</a>
    </div>
    <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {recent.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <!-- All categories -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Explore by category</h2>
    <div class="mt-4 space-y-8">
      {grouped.map((g) => (
        <div>
          <h3 class="font-semibold text-slate-900 dark:text-white">{g.category}</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {g.topics.map((t) => (
              <a href={`/topics/${t.slug}`} class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-sm transition-colors hover:border-brand-300 hover:bg-brand-50 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700 dark:hover:bg-slate-800">
                <span>{t.icon}</span>{t.title}
                <span class="text-xs text-slate-400">{t.postCount}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
