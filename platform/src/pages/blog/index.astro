---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicsByCategory, postsForTopic } from '../../lib/content';

const grouped = topicsByCategory();
const data = await Promise.all(
  grouped.map(async (g) => ({
    category: g.category,
    topics: await Promise.all(
      g.topics.map(async (t) => ({ topic: t, posts: await postsForTopic(t.slug) }))
    ),
  }))
);

const allPosts = data.flatMap((g) => g.topics.flatMap((t) => t.posts));
const postCount = allPosts.length;
const topicCount = data.reduce((n, g) => n + g.topics.length, 0);

const description = `Browse the complete archive of ${postCount} research-backed posts across ${topicCount} topics — strategy, decision-making, and mental models, organized by category for easy exploration.`;

const keywords = [
  'research blog archive',
  'all posts',
  'strategy articles',
  'decision-making',
  'mental models',
  'business research',
];

const blogUrl = new URL('/blog/', Astro.site).toString();

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'All Posts',
    description,
    url: blogUrl,
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: postCount,
      itemListElement: allPosts.map((post, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: new URL(`/blog/${post.id}/`, Astro.site).toString(),
        name: post.data.title,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
    ],
  },
];
---

<BaseLayout title="All Posts" description={description} jsonLd={jsonLd} keywords={keywords}>
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">All posts</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">The complete archive, organized by topic. Use <a href="/search" class="text-brand-600 hover:underline dark:text-brand-400">search</a> to find something specific.</p>

    <div class="mt-10 space-y-12">
      {data.map((g) => (
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">{g.category}</h2>
          <div class="mt-4 space-y-8">
            {g.topics.map(({ topic, posts }) => (
              <div>
                <a href={`/topics/${topic.slug}`} class="inline-flex items-center gap-2 font-semibold text-slate-900 hover:text-brand-700 dark:text-white dark:hover:text-brand-300">
                  <span>{topic.icon}</span>{topic.title}
                  <span class="text-xs font-normal text-slate-400">{posts.length}</span>
                </a>
                <ul class="mt-2 space-y-1 border-l border-slate-200 pl-4 dark:border-slate-800">
                  {posts.map((post) => (
                    <li>
                      <a href={`/blog/${post.id}`} class="block py-0.5 text-sm text-slate-600 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400">{post.data.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
